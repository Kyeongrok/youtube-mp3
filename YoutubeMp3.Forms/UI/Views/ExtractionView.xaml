<UserControl
    x:Class="YoutubeMp3.Forms.UI.Views.ExtractionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/YoutubeMp3.Forms;component/Themes/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Search  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SearchBox"
                Grid.Column="0"
                Style="{StaticResource DarkTextBoxStyle}"
                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>

            <!--  Placeholder: 검색어가 비어 있을 때만 표시  -->
            <TextBlock
                Grid.Column="0"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="#888888"
                IsHitTestVisible="False"
                Text="검색어를 입력하세요">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button
                Grid.Column="1"
                Width="80"
                Margin="8,0,0,0"
                Command="{Binding SearchCommand}"
                Content="검색"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <!--  Search results  -->
        <ListBox
            x:Name="ResultsList"
            Grid.Row="1"
            Margin="0,8,0,0"
            Background="#2D2D2D"
            BorderBrush="#3C3C3C"
            BorderThickness="1"
            ItemsSource="{Binding SearchResults}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}">
            <!--  검색 결과가 없으면 리스트를 숨긴다  -->
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="#3C3C3C" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3C3C3C" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0078D4" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="#999999">
                            <Run Text="{Binding Channel, Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{Binding Duration, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!--  검색 결과가 없을 때(검색 전 포함) 리스트 자리에 표시할 안내  -->
        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="13"
            Foreground="#888888"
            IsHitTestVisible="False"
            Text="검색어를 입력해 유튜브를 검색하세요">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasItems, ElementName=ResultsList}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!--  URL 입력 + 추출 버튼(입력 필드 바로 오른쪽)  -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="#CCCCCC"
                Text="URL" />
            <TextBox
                Grid.Column="1"
                Style="{StaticResource DarkTextBoxStyle}"
                Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="2"
                Width="100"
                Margin="8,0,0,0"
                Command="{Binding DownloadCommand}"
                Content="MP3 추출"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <StackPanel
            Grid.Row="3"
            Margin="0,12,0,0"
            Orientation="Horizontal">
            <Button
                Width="140"
                Height="40"
                Command="{Binding AddToPlaylistCommand}"
                Content="재생목록에 추가"
                FontSize="14"
                Style="{StaticResource AccentButtonStyle}" />

            <Button
                Width="120"
                Height="40"
                Margin="8,0,0,0"
                Command="{Binding OpenFolderCommand}"
                Content="폴더 열기"
                FontSize="14"
                Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>

        <ProgressBar
            Grid.Row="4"
            Height="6"
            Margin="0,16,0,0"
            Background="#2D2D2D"
            BorderThickness="0"
            Foreground="#0078D4"
            Maximum="100"
            Value="{Binding ProgressPercentage, Mode=OneWay}" />

        <TextBlock
            Grid.Row="5"
            Margin="0,8,0,0"
            FontSize="12"
            Foreground="#CCCCCC"
            Text="{Binding Status}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
