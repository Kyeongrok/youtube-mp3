<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:units="clr-namespace:YoutubeMp3.Support.UI.Units">

    <Style TargetType="{x:Type units:YoutubeMp3Window}">
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome
                    CaptionHeight="36"
                    CornerRadius="0"
                    GlassFrameThickness="0"
                    NonClientFrameEdges="None"
                    ResizeBorderThickness="5"
                    UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type units:YoutubeMp3Window}">
                    <Border
                        Background="#1E1E1E"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Title Bar  -->
                            <Grid Grid.Row="0" Background="#2D2D2D">
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#CCCCCC"
                                    Text="{TemplateBinding Title}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <!--  Minimize  -->
                                    <units:MinimizeButton x:Name="PART_MinimizeButton" />
                                    <!--  Maximize  -->
                                    <units:MaximizeButton x:Name="PART_MaximizeButton" />
                                    <!--  Close  -->
                                    <units:CloseButton x:Name="PART_CloseButton" />
                                </StackPanel>
                            </Grid>

                            <!--  Content Area  -->
                            <ContentPresenter Grid.Row="1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
