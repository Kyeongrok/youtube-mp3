<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lr="clr-namespace:LazyRegion.WPF;assembly=LazyRegion.WPF"
    xmlns:support="clr-namespace:YoutubeMp3.Support.UI.Units;assembly=YoutubeMp3.Support"
    xmlns:views="clr-namespace:YoutubeMp3.Forms.UI.Views">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/YoutubeMp3.Forms;component/Themes/SharedStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style BasedOn="{StaticResource {x:Type support:YoutubeMp3Window}}" TargetType="{x:Type views:MainWindow}">
        <Setter Property="Title" Value="YoutubeMp3" />
        <Setter Property="Icon" Value="/YoutubeMp3.Forms;component/Resources/app.ico" />
        <Setter Property="Width" Value="800" />
        <Setter Property="Height" Value="600" />
        <Setter Property="MinWidth" Value="400" />
        <Setter Property="MinHeight" Value="300" />
        <Setter Property="WindowStyle" Value="None" />

        <!--  타이틀바 가운데 내비게이션 버튼들 (각자 개별 화면으로 이동)  -->
        <Setter Property="TitleBarContent">
            <Setter.Value>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Width="130"
                        Height="26"
                        VerticalAlignment="Center"
                        Command="{Binding ShowExtractionCommand}"
                        Content="Youtube Mp3 추출"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style BasedOn="{StaticResource SecondaryButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExtractionActive}" Value="True">
                                        <Setter Property="Background" Value="#0078D4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button
                        Width="100"
                        Height="26"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding ShowVolumeCommand}"
                        Content="데시벨 조정"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style BasedOn="{StaticResource SecondaryButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVolumeActive}" Value="True">
                                        <Setter Property="Background" Value="#0078D4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button
                        Width="90"
                        Height="26"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding ShowPlayerCommand}"
                        Content="플레이어"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style BasedOn="{StaticResource SecondaryButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlayerActive}" Value="True">
                                        <Setter Property="Background" Value="#0078D4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Setter.Value>
        </Setter>

        <!--  본문: LazyRegion으로 추출/데시벨 화면을 애니메이션 전환  -->
        <Setter Property="Content">
            <Setter.Value>
                <lr:LazyRegion
                    Margin="24"
                    Content="{Binding CurrentPage}"
                    TransitionAnimation="Fade" />
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
