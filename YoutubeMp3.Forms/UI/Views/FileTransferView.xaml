<UserControl
    x:Class="YoutubeMp3.Forms.UI.Views.FileTransferView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/YoutubeMp3.Forms;component/Themes/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <!--  전송할 mp3 체크박스 목록  -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="White"
                Text="보낼 파일 선택 (체크한 파일이 QR에 반영됩니다)" />

            <ListBox
                x:Name="FilesList"
                Grid.Row="1"
                Margin="0,8,0,0"
                Background="#2D2D2D"
                BorderBrush="#3C3C3C"
                BorderThickness="1"
                ItemsSource="{Binding AvailableFiles}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#3C3C3C" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3C3C3C" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox
                            Margin="0,2"
                            VerticalContentAlignment="Center"
                            Foreground="White"
                            IsChecked="{Binding IsSelected, Mode=TwoWay}">
                            <TextBlock
                                FontSize="13"
                                Foreground="White"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  다운로드 폴더에 mp3가 없을 때 안내  -->
            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="#888888"
                IsHitTestVisible="False"
                Text="보낼 mp3가 없습니다. 먼저 추출/다운로드하세요">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasItems, ElementName=FilesList}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!--  QR + 링크 + 상태  -->
        <StackPanel
            Grid.Column="1"
            Margin="16,0,0,0"
            VerticalAlignment="Top">
            <Border
                Width="200"
                Height="200"
                HorizontalAlignment="Center"
                Background="White">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QrImage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Image
                    Margin="8"
                    Source="{Binding QrImage}"
                    Stretch="Uniform" />
            </Border>

            <TextBlock
                Margin="0,10,0,0"
                FontSize="12"
                Foreground="#CCCCCC"
                Text="{Binding Status}"
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <TextBlock
                Margin="0,4,0,0"
                FontSize="11"
                Foreground="#4CC2FF"
                Text="{Binding TransferUrl}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
